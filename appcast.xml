    <item>
      <title>Version 0.0.4-beta</title>
      <pubDate>Fri, 17 Jul 2026 08:19:44 +0000</pubDate>
      <sparkle:version>0.0.4-beta</sparkle:version>
      <sparkle:shortVersionString>0.0.4-beta</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
      <description><![CDATA[Improves reliability and privacy across Chromium and multi-window apps: accessibility activation no longer repeats across app switches, password managers, private windows, and credential-shaped text are excluded, screen OCR tracks the focused window and skips unchanged captures, and conversation context walks are time-bounded to keep typing responsive.]]></description>
      <enclosure url="https://github.com/awsleiman171/gibran-releases/releases/download/v0.0.4-beta/Gibran-0.0.4-beta.dmg"
