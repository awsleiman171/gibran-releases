    <item>
      <title>Version 0.0.2-beta</title>
      <pubDate>Mon, 06 Jul 2026 18:11:31 +0000</pubDate>
      <sparkle:version>0.0.2-beta</sparkle:version>
      <sparkle:shortVersionString>0.0.2-beta</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
      <description><![CDATA[Gibran can now read the conversation you are replying to even in apps that hide it from accessibility — opt-in under Settings → General → Read Screen When Text Is Hidden; the text is recognized on your Mac and never leaves it. Click a suggestion's popup card to accept all of it. Accepting mid-word now replaces the rest of the word cleanly. Suggestions arrive noticeably sooner (input debounce cut from 100 ms to 30 ms) and the confusing Suggestion Delay slider is gone. Onboarding checkmarks now reflect Input Monitoring grants live.]]></description>
      <enclosure url="https://github.com/awsleiman171/gibran-releases/releases/download/v0.0.2-beta/Gibran-0.0.2-beta.dmg"
                 sparkle:edSignature="qGwE5jjKKMhDFzYgCZq+cbY2wcW1jw8rpK6uYolYph2S8PWNcNBovmjTqwlk4Q+3MH8GSrE4Spa7Oo92PvYpCQ=="
                 length="12818663"
                 type="application/octet-stream"/>
    </item>
